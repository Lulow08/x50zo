<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.trifasico.x50zo.controller.GameController"
        prefWidth="800"
        prefHeight="600"
        styleClass="root-pane"
        focusTraversable="true">

    <!-- ================= TOP ================= -->

    <top>
        <HBox fx:id="topMachineArea"
              alignment="CENTER"
              spacing="40"
              prefHeight="120"/>
    </top>

    <!-- ================= LEFT ================= -->

    <left>
        <VBox alignment="CENTER_LEFT"
              spacing="2"
              prefWidth="220"
              style="-fx-padding: 0 0 0 16;">

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text=""
                        styleClass="btn-exit"
                        onAction="#onExitClicked"/>

                <Button text=""
                        styleClass="btn-home"
                        onAction="#onHomeClicked"/>
            </HBox>

            <Label text="TURN"
                   styleClass="label-turn-title"/>

            <Label fx:id="turnPlayerLabel"
                   text="YOUR TURN"
                   styleClass="turn-label-normal"/>

            <Label fx:id="statusLabel"
                   styleClass="status-label"/>

        </VBox>
    </left>

    <!-- ================= CENTER ================= -->

    <center>

        <StackPane>

            <VBox alignment="CENTER"
                  spacing="16">

                <HBox alignment="CENTER"
                      spacing="10">

                    <Label text="TABLE SUM:"
                           styleClass="board-title"/>

                    <Label fx:id="tableSumLabel"
                           text="0"
                           styleClass="table-sum"/>

                </HBox>

                <HBox alignment="CENTER"
                      spacing="30">

                    <VBox alignment="CENTER"
                          spacing="5">

                        <ImageView fx:id="deckView"
                                   styleClass="deck-view"
                                   fitWidth="90"
                                   fitHeight="130"
                                   preserveRatio="true"/>

                        <Label fx:id="deckCountLabel"
                               text="52/52"
                               styleClass="small-caption"/>

                    </VBox>

                    <VBox alignment="CENTER"
                          spacing="5">

                        <ImageView fx:id="topCardView"
                                   styleClass="top-card-view"
                                   fitWidth="90"
                                   fitHeight="130"
                                   preserveRatio="true"/>

                        <Label text="TOP CARD"
                               styleClass="small-caption"/>

                    </VBox>

                </HBox>

            </VBox>

            <Label fx:id="centerMessageLabel"
                   opacity="0.0"
                   mouseTransparent="true"/>

        </StackPane>

    </center>

    <!-- ================= RIGHT ================= -->

    <right>

        <VBox fx:id="rightMachineArea"
              alignment="CENTER"
              prefWidth="180"
              style="-fx-padding: 0 16 0 0;"/>

    </right>

    <!-- ================= BOTTOM ================= -->

    <bottom>

        <VBox alignment="CENTER"
              spacing="10"
              prefHeight="180"
              style="-fx-padding: 0 0 20 0;">

            <Label fx:id="humanNameLabel"
                   text="PLAYER 1"
                   styleClass="human-name"/>

            <HBox fx:id="humanHandBox"
                  alignment="CENTER"
                  spacing="16"
                  prefHeight="140"/>

        </VBox>

    </bottom>

</BorderPane>