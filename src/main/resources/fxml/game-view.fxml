<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.trifasico.x50zo.controller.GameController"
        prefWidth="860" prefHeight="600"
        styleClass="root-pane"
        focusTraversable="true">

    <center>
        <StackPane styleClass="main-stack">

            <!-- ── MACHINE HANDS (top area, absolutely positioned via VBox) ── -->
            <VBox alignment="TOP_CENTER" pickOnBounds="false">
                <HBox fx:id="machineArea"
                      alignment="TOP_CENTER"
                      spacing="40"
                      styleClass="machine-area"/>
            </VBox>

            <!-- ── LEFT PANEL: controls + turn info ── -->
            <VBox pickOnBounds="false">
                <VBox styleClass="left-panel" spacing="10">

                    <!-- Exit / Home buttons -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button styleClass="btn-exit"
                                text="✕"
                                onAction="#onExitClicked"/>
                        <Button styleClass="btn-home"
                                text="⌂"
                                onAction="#onHomeClicked"/>
                    </HBox>

                    <!-- Turn label -->
                    <Label text="TURN" styleClass="label-turn-title"/>
                    <Label fx:id="turnPlayerLabel"
                           text="—"
                           styleClass="label-turn-player"/>

                    <!-- Status (eliminated, reshuffle notices) -->
                    <Label fx:id="statusLabel"
                           styleClass="label-status"
                           wrapText="true"
                           maxWidth="150"/>
                </VBox>
            </VBox>

            <!-- ── CENTER: top card + sum ── -->
            <HBox alignment="CENTER" spacing="24" pickOnBounds="false">
                <StackPane styleClass="table-card-area">
                    <ImageView fx:id="topCardView"
                               fitWidth="100" fitHeight="145"
                               preserveRatio="true"/>
                </StackPane>
                <Label fx:id="tableSumLabel"
                       text="0"
                       styleClass="label-sum"/>
            </HBox>

            <!-- ── BOTTOM: human hand + name + deck ── -->
            <VBox alignment="BOTTOM_CENTER" pickOnBounds="false">
                <VBox styleClass="bottom-area" alignment="CENTER" spacing="8">

                    <!-- Hand row: cards + deck -->
                    <HBox alignment="CENTER" spacing="16">

                        <HBox fx:id="humanHandBox"
                              alignment="CENTER"
                              spacing="10"
                              styleClass="hand-box"/>

                        <!-- Deck pile -->
                        <VBox alignment="CENTER" spacing="4" styleClass="deck-box">
                            <ImageView fx:id="deckView"
                                       fitWidth="70" fitHeight="100"
                                       preserveRatio="true"/>
                            <Label fx:id="deckCountLabel"
                                   text="52/52"
                                   styleClass="label-deck-count"/>
                        </VBox>

                    </HBox>

                    <!-- Human name -->
                    <Label fx:id="humanNameLabel"
                           text="PLAYER 1"
                           styleClass="label-human-name"/>

                </VBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>